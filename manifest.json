<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Civics Quiz">
<meta name="theme-color" content="#7c6af7">
<meta name="description" content="Practice all 128 official USCIS civics test questions with voice recognition">
<link rel="manifest" href="./manifest.json">
<link rel="icon" href="./icons/icon-192.png">
<link rel="apple-touch-icon" href="./icons/icon-192.png">
<title>U.S. Civics Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0a0f; --surface:#111118; --card:#181824; --border:#252538;
  --accent:#7c6af7; --accent2:#f76a8f; --green:#4ade80; --red:#f87171;
  --amber:#fbbf24; --text:#e8e8f0; --muted:#5a5a7a; --glow:rgba(124,106,247,0.12);
  --safe-top: env(safe-area-inset-top, 0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --radius: 20px;
  --touch: 56px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{height:100%;overscroll-behavior:none;}
body{
  background:var(--bg); color:var(--text);
  font-family:'Syne',sans-serif;
  height:100%; min-height:100dvh;
  display:flex; flex-direction:column;
  overflow:hidden;
  padding-top:var(--safe-top);
  padding-bottom:var(--safe-bottom);
}

/* Background grid */
body::before{
  content:'';position:fixed;inset:0;
  background-image:linear-gradient(rgba(124,106,247,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(124,106,247,.025) 1px,transparent 1px);
  background-size:36px 36px;
  pointer-events:none;z-index:0;
}

/* Glow orbs */
.orb{position:fixed;border-radius:50%;filter:blur(80px);pointer-events:none;z-index:0;opacity:.35;}
.orb1{width:300px;height:300px;background:var(--accent);top:-80px;right:-80px;}
.orb2{width:260px;height:260px;background:var(--accent2);bottom:80px;left:-100px;}

.app{
  position:relative;z-index:1;
  display:flex;flex-direction:column;
  height:100dvh;
  overflow:hidden;
}

/* ===== SCREENS ===== */
.screen{display:none;flex-direction:column;flex:1;overflow:hidden;}
.screen.active{display:flex;}

/* ===== HEADER ===== */
.top-bar{
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 20px 10px;
  flex-shrink:0;
}
.logo{font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:7px;}
.logo-dot{width:5px;height:5px;background:var(--accent2);border-radius:50%;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.score-pill{font-family:'DM Mono',monospace;font-size:12px;background:var(--card);border:1px solid var(--border);padding:6px 14px;border-radius:100px;color:var(--muted);}
.score-pill span{color:var(--accent);}

/* ===== MENU SCREEN ===== */
.menu-scroll{flex:1;overflow-y:auto;padding:4px 20px 24px;-webkit-overflow-scrolling:touch;}
.menu-scroll::-webkit-scrollbar{display:none;}

.hero{margin-bottom:28px;}
.hero h1{font-size:36px;font-weight:800;letter-spacing:-.03em;line-height:1.1;margin-bottom:8px;}
.hero h1 em{font-style:normal;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero p{color:var(--muted);font-size:12px;font-family:'DM Mono',monospace;letter-spacing:.05em;}

.sec-label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;font-family:'DM Mono',monospace;}

/* Mode toggle */
.mode-pills{display:flex;gap:8px;margin-bottom:22px;background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:5px;}
.mode-pill{flex:1;padding:12px 8px;border:none;border-radius:10px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .2s;color:var(--muted);background:transparent;display:flex;align-items:center;justify-content:center;gap:6px;}
.mode-pill.active{background:var(--accent);color:white;box-shadow:0 4px 16px rgba(124,106,247,.4);}

/* Category chips */
.cat-wrap{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:22px;}
.chip{background:var(--surface);border:1px solid var(--border);border-radius:100px;padding:8px 14px;font-size:11px;font-family:'DM Mono',monospace;cursor:pointer;color:var(--muted);transition:all .2s;user-select:none;}
.chip.on{border-color:var(--accent);color:var(--accent);background:rgba(124,106,247,.1);font-weight:700;}

/* Count */
.count-row{display:flex;align-items:center;gap:12px;margin-bottom:28px;}
.count-lbl{font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap;}
input[type=range]{flex:1;-webkit-appearance:none;height:4px;background:var(--border);border-radius:4px;outline:none;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;box-shadow:0 2px 10px rgba(124,106,247,.5);}
.count-val{font-size:15px;font-family:'DM Mono',monospace;color:var(--accent);min-width:32px;text-align:right;font-weight:700;}

.btn-go{
  width:100%;padding:19px;
  background:linear-gradient(135deg,var(--accent),#a594f9);
  border:none;border-radius:var(--radius);
  color:white;font-family:'Syne',sans-serif;font-size:17px;font-weight:800;
  letter-spacing:.04em;cursor:pointer;
  box-shadow:0 6px 28px rgba(124,106,247,.45);
  transition:transform .15s, box-shadow .15s;
  position:relative;overflow:hidden;
}
.btn-go:active{transform:scale(.97);box-shadow:0 2px 12px rgba(124,106,247,.3);}
.btn-go::after{content:'→';margin-left:8px;}

/* ===== QUIZ SCREEN ===== */
.quiz-top{padding:0 20px 12px;flex-shrink:0;}
.prog-row{display:flex;align-items:center;gap:12px;}
.prog-track{flex:1;height:4px;background:var(--border);border-radius:4px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:4px;transition:width .4s ease;}
.prog-txt{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);white-space:nowrap;}

/* Question card */
.q-card{
  margin:0 16px 14px;
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:24px 22px;
  position:relative;overflow:hidden;
  flex-shrink:0;
  animation:cardIn .4s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes cardIn{from{opacity:0;transform:scale(.96) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
.q-card::before{content:'';position:absolute;top:-40px;right:-40px;width:120px;height:120px;background:radial-gradient(circle,var(--glow),transparent 70%);border-radius:50%;}
.q-meta{display:flex;align-items:center;gap:8px;margin-bottom:14px;}
.q-num{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);opacity:.8;}
.q-cat{font-family:'DM Mono',monospace;font-size:10px;background:rgba(247,106,143,.1);color:var(--accent2);border:1px solid rgba(247,106,143,.2);padding:3px 9px;border-radius:100px;}
.q-text{font-size:clamp(17px,4vw,22px);font-weight:700;letter-spacing:-.02em;line-height:1.3;margin-bottom:0;}
.result-badge{position:absolute;top:14px;right:14px;padding:4px 10px;border-radius:100px;font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;display:none;animation:pop .35s cubic-bezier(.34,1.56,.64,1) both;}
@keyframes pop{from{opacity:0;transform:scale(.4)}to{opacity:1;transform:scale(1)}}
.result-badge.ok{background:rgba(74,222,128,.15);color:var(--green);border:1px solid var(--green);display:block;}
.result-badge.no{background:rgba(248,113,113,.15);color:var(--red);border:1px solid var(--red);display:block;}
.result-badge.sk{background:rgba(90,90,122,.15);color:var(--muted);border:1px solid var(--muted);display:block;}

/* Scrollable area below card */
.quiz-scroll{flex:1;overflow-y:auto;padding:0 16px;-webkit-overflow-scrolling:touch;}
.quiz-scroll::-webkit-scrollbar{display:none;}

/* Answer input */
.input-wrap{margin-bottom:12px;}
.input-box{
  width:100%;padding:15px 18px;
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:14px;
  color:var(--text);font-family:'DM Mono',monospace;font-size:15px;
  outline:none;transition:border-color .2s;
}
.input-box::placeholder{color:var(--muted);}
.input-box:focus{border-color:var(--accent);}
.input-box:disabled{opacity:.45;}
.submit-btn{
  width:100%;margin-top:8px;padding:15px;
  background:var(--surface);border:1.5px solid var(--accent);
  border-radius:14px;
  color:var(--accent);font-family:'Syne',sans-serif;font-size:14px;font-weight:700;
  cursor:pointer;transition:all .2s;letter-spacing:.04em;
}
.submit-btn:active:not(:disabled){background:rgba(124,106,247,.15);}
.submit-btn:disabled{opacity:.35;cursor:not-allowed;}

/* Voice strip */
.voice-strip{
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:14px;padding:14px 16px;
  display:flex;align-items:center;gap:10px;
  font-family:'DM Mono',monospace;font-size:13px;color:var(--muted);
  transition:all .25s;min-height:50px;margin-bottom:12px;
}
.voice-strip.listening{border-color:var(--accent2);color:var(--accent2);}
.voice-strip.ok{border-color:var(--green);background:rgba(74,222,128,.05);color:var(--green);}
.voice-strip.no{border-color:var(--red);background:rgba(248,113,113,.05);color:var(--red);}
.voice-strip.has{color:var(--text);border-color:var(--border);}
.v-icon{font-size:16px;flex-shrink:0;}

/* Answer reveal */
.reveal{
  background:var(--surface);border:1.5px solid var(--border);
  border-radius:14px;padding:16px 18px;
  display:none;margin-bottom:12px;
  animation:fadeUp .3s ease both;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.reveal.show{display:block;}
.reveal-lbl{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-family:'DM Mono',monospace;margin-bottom:8px;}
.reveal-main{font-size:16px;font-weight:700;color:var(--text);line-height:1.4;}
.reveal-also{font-size:11px;color:var(--muted);font-family:'DM Mono',monospace;margin-top:6px;line-height:1.6;}

/* Bottom action buttons */
.quiz-actions{
  display:flex;gap:8px;
  padding:12px 16px 16px;
  flex-shrink:0;
  background:linear-gradient(to top, var(--bg) 70%, transparent);
}
.act-btn{
  flex:1;min-height:var(--touch);
  border-radius:16px;border:1.5px solid var(--border);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;
  cursor:pointer;transition:all .15s;
  font-family:'Syne',sans-serif;
}
.act-btn:active:not(:disabled){transform:scale(.94);}
.act-btn:disabled{opacity:.3;cursor:not-allowed;}
.act-icon{font-size:24px;line-height:1;}
.act-lbl{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}

.act-speak{background:rgba(247,106,143,.1);color:var(--accent2);border-color:rgba(247,106,143,.3);}
.act-speak.rec{animation:glow 1s infinite;}
@keyframes glow{0%,100%{box-shadow:0 0 0 0 rgba(247,106,143,.5)}50%{box-shadow:0 0 0 10px rgba(247,106,143,0)}}
.act-show{background:rgba(124,106,247,.1);color:var(--accent);border-color:rgba(124,106,247,.3);}
.act-next{background:rgba(74,222,128,.1);color:var(--green);border-color:rgba(74,222,128,.3);}
.act-next.big{flex:1.4;background:linear-gradient(135deg,rgba(74,222,128,.15),rgba(74,222,128,.05));}

/* ===== RESULTS SCREEN ===== */
.results-body{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 20px;gap:18px;overflow-y:auto;}
.results-body::-webkit-scrollbar{display:none;}
.r-emoji{font-size:72px;animation:bounce .6s cubic-bezier(.34,1.56,.64,1) both;}
@keyframes bounce{from{transform:scale(0) rotate(-15deg)}to{transform:scale(1) rotate(0)}}
.r-title{font-size:30px;font-weight:800;letter-spacing:-.03em;}
.r-pct{font-family:'DM Mono',monospace;font-size:72px;font-weight:300;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
.r-sub{color:var(--muted);font-family:'DM Mono',monospace;font-size:13px;}
.pass-chip{padding:8px 20px;border-radius:100px;font-size:12px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;}
.pass-chip.y{background:rgba(74,222,128,.15);color:var(--green);border:1.5px solid var(--green);}
.pass-chip.n{background:rgba(248,113,113,.15);color:var(--red);border:1.5px solid var(--red);}
.r-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;width:100%;}
.r-box{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px 12px;text-align:center;}
.r-num{font-size:30px;font-weight:800;letter-spacing:-.02em;}
.r-num.c{color:var(--green);}
.r-num.w{color:var(--red);}
.r-num.s{color:var(--muted);}
.r-lbl{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-family:'DM Mono',monospace;margin-top:4px;}
.r-btns{display:flex;gap:10px;width:100%;}
.btn-again,.btn-back{flex:1;padding:17px;border-radius:var(--radius);font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer;transition:all .15s;letter-spacing:.04em;}
.btn-again{background:linear-gradient(135deg,var(--accent),#a594f9);border:none;color:white;box-shadow:0 4px 20px rgba(124,106,247,.4);}
.btn-again:active{transform:scale(.96);}
.btn-back{background:var(--card);border:1.5px solid var(--border);color:var(--text);}
.btn-back:active{border-color:var(--accent);color:var(--accent);}

/* Toast */
.toast{position:fixed;bottom:calc(20px + var(--safe-bottom));left:50%;transform:translateX(-50%);background:rgba(24,24,36,.95);backdrop-filter:blur(12px);border:1px solid var(--border);color:var(--text);font-family:'DM Mono',monospace;font-size:12px;padding:10px 20px;border-radius:100px;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;max-width:90vw;text-align:center;}
.toast.show{opacity:1;}

/* Install banner */
.install-banner{
  display:none;
  margin:0 16px 12px;
  background:linear-gradient(135deg,rgba(124,106,247,.15),rgba(247,106,143,.1));
  border:1px solid rgba(124,106,247,.3);
  border-radius:14px;padding:14px 16px;
  flex-direction:row;align-items:center;gap:12px;
}
.install-banner.show{display:flex;}
.install-text{flex:1;font-size:12px;font-family:'DM Mono',monospace;color:var(--text);line-height:1.5;}
.install-text strong{color:var(--accent);display:block;margin-bottom:2px;}
.btn-install{background:var(--accent);border:none;border-radius:10px;color:white;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;padding:9px 14px;cursor:pointer;white-space:nowrap;}
.btn-dismiss{background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;padding:4px;}
</style>
</head>
<body>
<div class="orb orb1"></div>
<div class="orb orb2"></div>

<div class="app">

  <!-- Install banner (shown when installable) -->
  <div class="install-banner" id="installBanner">
    <div class="install-text"><strong>📲 Add to Home Screen</strong>Tap to install as an app — works offline!</div>
    <button class="btn-install" id="installBtn">Install</button>
    <button class="btn-dismiss" onclick="dismissInstall()">×</button>
  </div>

  <!-- ===== MENU ===== -->
  <div class="screen active" id="menuScreen">
    <div class="top-bar">
      <div class="logo"><div class="logo-dot"></div>Civics Quiz</div>
      <div style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);">128 Q · 2025</div>
    </div>
    <div class="menu-scroll">
      <div class="hero">
        <h1>Master the<br><em>U.S. Civics</em><br>Test.</h1>
        <p>// official USCIS questions · voice + text</p>
      </div>

      <div class="sec-label">Quiz mode</div>
      <div class="mode-pills" style="margin-bottom:22px;">
        <button class="mode-pill active" id="mVoice" onclick="setMode('voice')">🎙️ Voice</button>
        <button class="mode-pill" id="mStudy" onclick="setMode('study')">📖 Study</button>
      </div>

      <div class="sec-label">Categories</div>
      <div class="cat-wrap" id="catWrap"></div>

      <div class="sec-label" style="margin-top:20px;">Number of questions</div>
      <div class="count-row">
        <span class="count-lbl">Questions:</span>
        <input type="range" id="qSlider" min="5" max="128" value="20" oninput="onSlide()">
        <span class="count-val" id="qVal">20</span>
      </div>

      <button class="btn-go" onclick="startQuiz()">Start Quiz</button>
      <div style="height:20px;"></div>
    </div>
  </div>

  <!-- ===== QUIZ ===== -->
  <div class="screen" id="quizScreen">
    <div class="top-bar">
      <div class="logo"><div class="logo-dot"></div>Civics Quiz</div>
      <div class="score-pill" id="scorePill" style="display:none">Score: <span id="sNum">0</span>/<span id="sTotal">0</span></div>
    </div>
    <div class="quiz-top">
      <div class="prog-row">
        <div class="prog-track"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
        <div class="prog-txt" id="progTxt">0 / 0</div>
      </div>
    </div>

    <div class="q-card" id="qCard">
      <div class="q-meta">
        <div class="q-num" id="qNum">Q 1</div>
        <div class="q-cat" id="qCat"></div>
      </div>
      <div class="q-text" id="qTxt">...</div>
      <div class="result-badge" id="resBadge"></div>
    </div>

    <div class="quiz-scroll" id="quizScroll">
      <div class="input-wrap">
        <input type="text" class="input-box" id="ansInput" placeholder="Type your answer…" autocomplete="off" autocorrect="off" spellcheck="false" onkeydown="onKey(event)">
        <button class="submit-btn" id="subBtn" onclick="submitText()">Submit Answer</button>
      </div>

      <div class="voice-strip" id="vStrip">
        <span class="v-icon" id="vIcon">💬</span>
        <span id="vTxt">Speak or type your answer</span>
      </div>

      <div class="reveal" id="reveal">
        <div class="reveal-lbl">✓ Accepted answer</div>
        <div class="reveal-main" id="revMain"></div>
        <div class="reveal-also" id="revAlso"></div>
      </div>
    </div>

    <div class="quiz-actions">
      <button class="act-btn act-speak" id="speakBtn" onclick="toggleMic()">
        <span class="act-icon" id="micIco">🎙️</span>
        <span class="act-lbl">Speak</span>
      </button>
      <button class="act-btn act-show" id="showBtn" onclick="showAns()">
        <span class="act-icon">👁️</span>
        <span class="act-lbl">Show</span>
      </button>
      <button class="act-btn act-next big" id="nextBtn" onclick="nextQ()">
        <span class="act-icon">→</span>
        <span class="act-lbl">Next</span>
      </button>
    </div>
  </div>

  <!-- ===== RESULTS ===== -->
  <div class="screen" id="resultsScreen">
    <div class="top-bar">
      <div class="logo"><div class="logo-dot"></div>Results</div>
    </div>
    <div class="results-body">
      <div class="r-emoji" id="rEmoji">🏆</div>
      <div class="r-title">Quiz Complete!</div>
      <div class="r-pct" id="rPct">0%</div>
      <div class="r-sub" id="rSub">0 of 0 correct</div>
      <div class="pass-chip" id="rPass"></div>
      <div class="r-grid">
        <div class="r-box"><div class="r-num c" id="rC">0</div><div class="r-lbl">Correct</div></div>
        <div class="r-box"><div class="r-num w" id="rW">0</div><div class="r-lbl">Wrong</div></div>
        <div class="r-box"><div class="r-num s" id="rS">0</div><div class="r-lbl">Skipped</div></div>
      </div>
      <div class="r-btns">
        <button class="btn-again" onclick="startQuiz()">Try Again</button>
        <button class="btn-back" onclick="goMenu()">← Menu</button>
      </div>
    </div>
  </div>

</div><!-- .app -->

<div class="toast" id="toast"></div>

<script>
// =========================================================
// DATA — all 128 official USCIS 2025 civics Q&A
// =========================================================
const QA = [
  {q:"What is the form of government of the United States?",a:["Republic","Constitution-based federal republic","Representative democracy"],c:"Principles"},
  {q:"What is the supreme law of the land?",a:["Constitution","U.S. Constitution"],c:"Principles"},
  {q:"Name one thing the U.S. Constitution does.",a:["Forms the government","Defines powers of government","Defines the parts of government","Protects the rights of the people"],c:"Principles"},
  {q:'What does "We the People" mean?',a:["Self-government","Popular sovereignty","Consent of the governed","People should govern themselves","Social contract"],c:"Principles"},
  {q:"How are changes made to the U.S. Constitution?",a:["Amendments","The amendment process"],c:"Principles"},
