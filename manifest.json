// =========================================================
// STATE
// =========================================================
const CATS = [...new Set(QA.map(q=>q.c))];
let selCats = new Set(CATS);
let mode = 'voice';
let qCount = 20;
let deck = [], idx = 0;
let score = {c:0,w:0,s:0};
let rec = null;
let answered = false;
let deferredPrompt = null;

// =========================================================
// INSTALL PWA
// =========================================================
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById('installBanner').classList.add('show');
});
document.getElementById('installBtn').onclick = async () => {
  if(!deferredPrompt) return;
  deferredPrompt.prompt();
  const {outcome} = await deferredPrompt.userChoice;
  deferredPrompt = null;
  document.getElementById('installBanner').classList.remove('show');
  if(outcome==='accepted') toast('🎉 Installing…');
};
function dismissInstall(){document.getElementById('installBanner').classList.remove('show');}
window.addEventListener('appinstalled', () => toast('✅ Installed! Find it on your home screen.'));

// =========================================================
// SERVICE WORKER
// =========================================================
if('serviceWorker' in navigator){
  navigator.serviceWorker.register('./sw.js').catch(()=>{});
}

// =========================================================
// TOAST
// =========================================================
let toastTimer;
function toast(msg, dur=3000){
  const el=document.getElementById('toast');
  el.textContent=msg;el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('show'),dur);
}

// =========================================================
// MENU
// =========================================================
function buildChips(){
  const wrap=document.getElementById('catWrap');wrap.innerHTML='';
  // All
  const all=mkChip('All (128)','all');all.classList.add('on');
  all.onclick=()=>toggleAll();wrap.appendChild(all);
  CATS.forEach(cat=>{
    const n=QA.filter(q=>q.c===cat).length;
    const ch=mkChip(`${cat} (${n})`,cat);ch.classList.add('on');
    ch.onclick=()=>toggleCat(cat,ch);wrap.appendChild(ch);
  });
}
function mkChip(txt,id){const d=document.createElement('div');d.className='chip';d.id='ch-'+id;d.textContent=txt;return d;}
function toggleAll(){
  if(selCats.size===CATS.length){selCats.clear();document.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));}
  else{selCats=new Set(CATS);document.querySelectorAll('.chip').forEach(c=>c.classList.add('on'));}
  updateMax();
}
function toggleCat(cat,el){
  selCats.has(cat)?selCats.delete(cat):selCats.add(cat);
  el.classList.toggle('on',selCats.has(cat));
  document.getElementById('ch-all').classList.toggle('on',selCats.size===CATS.length);
  updateMax();
}
function updateMax(){
  const pool=QA.filter(q=>selCats.has(q.c));
  const s=document.getElementById('qSlider');
  s.max=pool.length;s.value=Math.min(parseInt(s.value),pool.length);
  onSlide();
}
function onSlide(){qCount=parseInt(document.getElementById('qSlider').value);document.getElementById('qVal').textContent=qCount;}
function setMode(m){
  mode=m;
  document.getElementById('mVoice').classList.toggle('active',m==='voice');
  document.getElementById('mStudy').classList.toggle('active',m==='study');
}

// =========================================================
// QUIZ
// =========================================================
function startQuiz(){
  const pool=QA.filter(q=>selCats.has(q.c));
  if(!pool.length){toast('⚠️ Select at least one category');return;}
  deck=shuffle([...pool]).slice(0,qCount);
  idx=0;score={c:0,w:0,s:0};
  document.getElementById('scorePill').style.display='flex';
  document.getElementById('sTotal').textContent=deck.length;
  updateScore();
  show('quizScreen');
  loadQ();
}

function updateScore(){document.getElementById('sNum').textContent=score.c;}

function loadQ(){
  if(idx>=deck.length){endQuiz();return;}
  answered=false;
  const qa=deck[idx];
  document.getElementById('qNum').textContent=`Q ${idx+1}`;
  document.getElementById('qCat').textContent=qa.c;
  document.getElementById('qTxt').textContent=qa.q;
  document.getElementById('resBadge').className='result-badge';
  document.getElementById('resBadge').textContent='';
  document.getElementById('revMain').textContent=qa.a[0];
  document.getElementById('revAlso').textContent=qa.a.length>1?'Also: '+qa.a.slice(1,5).join(' · ')+(qa.a.length>5?' …':''):'';
  document.getElementById('reveal').classList.remove('show');
  // Reset voice strip
  setVStrip('💬','Speak or type your answer','');
  // Reset input
  const inp=document.getElementById('ansInput');
  inp.value='';inp.disabled=false;inp.readOnly=false;
  document.getElementById('subBtn').disabled=false;
  // Buttons
  document.getElementById('speakBtn').disabled=mode==='study';
  document.getElementById('speakBtn').style.opacity=mode==='study'?'0.3':'1';
  document.getElementById('showBtn').disabled=false;
  document.getElementById('nextBtn').disabled=false;
  // Progress
  document.getElementById('progFill').style.width=`${(idx/deck.length)*100}%`;
  document.getElementById('progTxt').textContent=`${idx} / ${deck.length}`;
  // Scroll top
  document.getElementById('quizScroll').scrollTop=0;
  // Read question aloud
  speakTTS(qa.q);
  // Focus input (slight delay so keyboard doesn't interrupt TTS on some devices)
  setTimeout(()=>{if(!answered)document.getElementById('ansInput').focus();},400);
}

function setVStrip(icon,txt,cls){
  document.getElementById('vIcon').textContent=icon;
  document.getElementById('vTxt').textContent=txt;
  document.getElementById('vStrip').className='voice-strip'+(cls?' '+cls:'');
}

// Text submit
function onKey(e){if(e.key==='Enter')submitText();}
function submitText(){
  const v=document.getElementById('ansInput').value.trim();
  if(!v){toast('⚠️ Type something first');return;}
  if(answered)return;
  evaluate(v);
}

// MIC
const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
function toggleMic(){
  if(answered)return;
  if(!SR){toast('❌ Open in Chrome for mic support');return;}
  const btn=document.getElementById('speakBtn');
  if(rec){rec.abort();rec=null;resetMic();return;}
  btn.classList.add('rec');
  document.getElementById('micIco').textContent='⏹️';
  setVStrip('🎤','Listening… speak now','listening');
  rec=new SR();
  rec.lang='en-US';rec.interimResults=false;rec.maxAlternatives=5;
  rec.onresult=e=>{
    const qa=deck[idx];
    let best=e.results[0][0].transcript;
    for(let i=0;i<e.results[0].length;i++){
      if(checkAns(e.results[0][i].transcript,qa.a)){best=e.results[0][i].transcript;break;}
    }
    document.getElementById('ansInput').value=best;
    evaluate(best);
  };
  rec.onerror=e=>{
    if(e.error==='not-allowed')toast('❌ Mic blocked — tap the 🔒 icon in Chrome and allow Microphone');
    else if(e.error!=='aborted')toast('⚠️ Mic error: '+e.error);
    resetMic();
  };
  rec.onend=resetMic;
  rec.start();
}
function resetMic(){
  const btn=document.getElementById('speakBtn');
  btn.classList.remove('rec');
  document.getElementById('micIco').textContent='🎙️';
  rec=null;
}

function evaluate(text){
  const qa=deck[idx];
  const ok=checkAns(text,qa.a);
  answered=true;
  document.getElementById('ansInput').disabled=true;
  document.getElementById('subBtn').disabled=true;
  if(ok){
    score.c++;
    setVStrip('✓',text,'ok');
    document.getElementById('resBadge').textContent='✓ CORRECT';
    document.getElementById('resBadge').className='result-badge ok';
    speakTTS('Correct!');
  } else {
    score.w++;
    setVStrip('✗',text,'no');
    document.getElementById('resBadge').textContent='✗ INCORRECT';
    document.getElementById('resBadge').className='result-badge no';
    document.getElementById('reveal').classList.add('show');
    speakTTS('Incorrect. The answer is: '+qa.a[0]);
  }
  updateScore();
}

function showAns(){
  const qa=deck[idx];
  document.getElementById('reveal').classList.add('show');
  if(!answered){
    answered=true;score.s++;
    document.getElementById('resBadge').textContent='— SKIPPED';
    document.getElementById('resBadge').className='result-badge sk';
    document.getElementById('ansInput').disabled=true;
    document.getElementById('subBtn').disabled=true;
    updateScore();
  }
  speakTTS(qa.a[0]);
}

function nextQ(){
  if(rec){rec.abort();rec=null;resetMic();}
  window.speechSynthesis&&window.speechSynthesis.cancel();
  if(!answered){score.s++;updateScore();}
  idx++;loadQ();
}

// =========================================================
// TTS
// =========================================================
function speakTTS(text){
  if(!window.speechSynthesis)return;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.rate=0.9;u.pitch=1;
  const voices=window.speechSynthesis.getVoices();
  const v=voices.find(v=>v.lang==='en-US'&&(v.name.includes('Google')||v.name.includes('Samantha')||v.name.includes('Alex')))||voices.find(v=>v.lang.startsWith('en'));
  if(v)u.voice=v;
  window.speechSynthesis.speak(u);
}
window.speechSynthesis&&window.speechSynthesis.addEventListener('voiceschanged',()=>{});

// =========================================================
// RESULTS
// =========================================================
function endQuiz(){
  const total=deck.length;
  const pct=Math.round((score.c/total)*100);
  document.getElementById('rPct').textContent=pct+'%';
  document.getElementById('rSub').textContent=`${score.c} of ${total} correct`;
  document.getElementById('rC').textContent=score.c;
  document.getElementById('rW').textContent=score.w;
  document.getElementById('rS').textContent=score.s;
  document.getElementById('rEmoji').textContent=pct===100?'🏆':pct>=80?'🌟':pct>=60?'👍':pct>=40?'💪':'📚';
  const p=document.getElementById('rPass');
  p.textContent=pct>=60?'✓ PASSING SCORE':'✗ Below passing — keep studying!';
  p.className='pass-chip '+(pct>=60?'y':'n');
  document.getElementById('progFill').style.width='100%';
  document.getElementById('scorePill').style.display='none';
  show('resultsScreen');
  speakTTS(`Quiz complete! You scored ${pct} percent. ${score.c} correct out of ${total}.`);
}

function goMenu(){
  window.speechSynthesis&&window.speechSynthesis.cancel();
  if(rec){rec.abort();rec=null;}
  document.getElementById('scorePill').style.display='none';
  show('menuScreen');
}

// =========================================================
// UTILS
// =========================================================
function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function norm(s){return s.toLowerCase().replace(/[^a-z0-9\s]/g,'').trim();}
function checkAns(spoken,answers){
  const s=norm(spoken);
  return answers.some(a=>{
    const c=norm(a);
    if(s===c||s.includes(c))return true;
    const w=c.split(/\s+/).filter(x=>x.length>2);
    return w.length>0&&w.every(x=>s.includes(x));
  });
}

// =========================================================
// INIT
// =========================================================
buildChips();onSlide();
</script>
